<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover, interactive-widget=resizes-content" />
<meta name="theme-color" content="#0A0E1F" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<title>NotebookAI</title>
<style>
  :root{
    --bg:#0A0E1F; --surface:#111827; --card:#1A2235; --border:#2D3748;
    --violet:#7B5CF0; --violet-light:#9B7FF5; --violet-dim:#3D2D7A;
    --emerald:#10B981; --emerald-dim:#064E3B;
    --white:#F8FAFC; --muted:#94A3B8; --red:#EF4444;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  html,body{height:100%;}
  body{
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg); color:var(--white);
    overscroll-behavior:none;
  }
  #app{display:flex;flex-direction:column;height:100vh;height:100dvh;}
  .screen{display:flex;flex-direction:column;height:100%;overflow:hidden;}
  .hidden{display:none !important;}

  .topbar{
    display:flex;align-items:center;justify-content:space-between;
    padding:14px 16px;border-bottom:1px solid var(--border);flex-shrink:0;
  }
  .topbar h1{font-size:18px;font-weight:700;display:flex;align-items:center;gap:8px;}
  .sub{font-size:12px;color:var(--muted);font-weight:400;}
  .icon-btn{
    background:none;border:none;color:var(--white);font-size:19px;
    width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;
    cursor:pointer;flex-shrink:0;
  }
  .icon-btn:active{background:var(--card);}
  .scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;}

  /* Setup */
  .setup-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;text-align:center;overflow-y:auto;}
  .setup-icon{font-size:40px;background:var(--violet-dim);width:78px;height:78px;border-radius:20px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;flex-shrink:0;}
  .setup-wrap h2{font-size:24px;font-weight:800;margin-bottom:6px;}
  .setup-wrap p{color:var(--muted);font-size:14px;margin-bottom:18px;line-height:1.5;}
  .info-card{background:var(--surface);border-radius:14px;padding:16px;text-align:left;width:100%;max-width:420px;margin-bottom:16px;}
  .info-card b{display:block;margin-bottom:8px;font-size:14px;}
  .info-card ol{padding-left:18px;color:var(--muted);font-size:13px;line-height:1.7;}
  .info-card code{background:var(--card);padding:1px 5px;border-radius:4px;font-size:12px;}
  textarea, input[type=text], input[type=url]{
    width:100%;max-width:420px;background:var(--surface);border:1px solid var(--border);
    color:var(--white);border-radius:12px;padding:12px 14px;font-size:14px;font-family:inherit;
  }
  textarea{font-family:ui-monospace,monospace;resize:vertical;}
  textarea:focus, input:focus{outline:none;border-color:var(--violet);}
  .btn{
    background:var(--violet);color:white;border:none;border-radius:12px;
    padding:14px 20px;font-size:15px;font-weight:600;cursor:pointer;
    width:100%;max-width:420px;margin-top:12px;display:flex;align-items:center;justify-content:center;gap:8px;
  }
  .btn:disabled{opacity:0.5;}
  .btn.outline{background:transparent;border:1px solid var(--border);color:var(--white);}
  .error-text{color:var(--red);font-size:13px;margin-top:8px;max-width:420px;text-align:left;width:100%;}

  /* Home */
  .fab{
    position:fixed;bottom:22px;right:18px;background:var(--violet);color:white;
    border:none;border-radius:30px;padding:14px 22px;font-size:15px;font-weight:600;
    display:flex;align-items:center;gap:8px;box-shadow:0 6px 20px rgba(123,92,240,0.4);
    cursor:pointer;z-index:50;
  }
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;padding:16px;padding-bottom:90px;}
  .nb-card{background:var(--surface);border-radius:16px;padding:16px;cursor:pointer;position:relative;}
  .nb-card .emoji{font-size:30px;display:block;margin-bottom:10px;}
  .nb-card h3{font-size:14px;font-weight:600;margin-bottom:4px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
  .nb-card p{font-size:12px;color:var(--muted);}
  .nb-card .del{position:absolute;top:10px;right:10px;font-size:15px;color:var(--muted);padding:4px;}
  .empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px;text-align:center;}
  .empty .em{font-size:52px;margin-bottom:14px;}
  .empty h3{font-size:19px;font-weight:700;margin-bottom:8px;}
  .empty p{color:var(--muted);font-size:14px;line-height:1.5;}

  /* Notebook */
  .chips{display:flex;gap:8px;overflow-x:auto;padding:10px 16px;border-bottom:1px solid var(--border);flex-shrink:0;}
  .chip{display:flex;align-items:center;gap:5px;background:var(--card);border-radius:20px;padding:6px 10px;font-size:12px;white-space:nowrap;flex-shrink:0;}
  .chip .x{color:var(--muted);font-size:13px;padding-left:2px;}
  .tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0;}
  .tab{flex:1;text-align:center;padding:12px;font-size:14px;font-weight:500;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;}
  .tab.active{color:var(--violet-light);border-bottom-color:var(--violet);font-weight:700;}

  .chat-area{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;-webkit-overflow-scrolling:touch;}
  .msg{display:flex;gap:8px;max-width:88%;}
  .msg.user{align-self:flex-end;flex-direction:row-reverse;}
  .msg .avatar{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;background:var(--emerald-dim);}
  .msg.user .avatar{background:var(--violet-dim);}
  .bubble{background:var(--card);border-radius:14px;padding:10px 13px;font-size:14px;line-height:1.5;white-space:pre-wrap;word-break:break-word;}
  .msg.user .bubble{background:var(--violet);color:white;}
  .chat-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:30px;text-align:center;color:var(--muted);font-size:13px;line-height:1.5;}
  .chat-empty .em{font-size:38px;margin-bottom:10px;}
  .typing{display:flex;gap:4px;padding:12px 13px;background:var(--card);border-radius:14px;width:fit-content;}
  .typing span{width:6px;height:6px;border-radius:50%;background:var(--emerald);opacity:0.4;animation:blink 1.2s infinite;}
  .typing span:nth-child(2){animation-delay:0.2s;} .typing span:nth-child(3){animation-delay:0.4s;}
  @keyframes blink{0%,80%,100%{opacity:0.3;}40%{opacity:1;}}

  .input-bar{display:flex;gap:8px;padding:10px 12px;border-top:1px solid var(--border);align-items:flex-end;flex-shrink:0;}
  .input-bar textarea{flex:1;max-height:100px;border-radius:22px;font-family:inherit;font-size:14px;padding:11px 16px;}
  .send-btn{width:42px;height:42px;border-radius:50%;background:var(--violet);border:none;color:white;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;cursor:pointer;}
  .send-btn:disabled{opacity:0.4;}

  .notes-list{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px;}
  .note-card{background:var(--surface);border-radius:12px;padding:14px;position:relative;}
  .note-card h4{font-size:14px;margin-bottom:4px;padding-right:20px;}
  .note-card p{font-size:13px;color:var(--muted);white-space:pre-wrap;}
  .note-card .del{position:absolute;top:10px;right:10px;color:var(--muted);font-size:14px;}

  .overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);display:flex;align-items:flex-end;justify-content:center;z-index:100;}
  .overlay.center{align-items:center;padding:20px;}
  .sheet{background:var(--surface);border-radius:20px 20px 0 0;width:100%;max-width:480px;padding:20px;max-height:80vh;overflow-y:auto;animation:slideup 0.2s ease;}
  .overlay.center .sheet{border-radius:18px;max-height:85vh;}
  @keyframes slideup{from{transform:translateY(30px);opacity:0;}to{transform:translateY(0);opacity:1;}}
  .sheet h2{font-size:20px;font-weight:700;margin-bottom:4px;}
  .sheet .desc{color:var(--muted);font-size:13px;margin-bottom:16px;line-height:1.4;}
  .opt-row{display:flex;align-items:center;gap:14px;padding:10px 0;cursor:pointer;}
  .opt-row .ic{width:44px;height:44px;border-radius:12px;background:var(--card);display:flex;align-items:center;justify-content:center;font-size:21px;flex-shrink:0;}
  .opt-row .tx{flex:1;}
  .opt-row .tx b{display:block;font-size:14px;}
  .opt-row .tx span{font-size:12px;color:var(--muted);}
  .row-gap{display:flex;gap:10px;margin-top:14px;}
  .row-gap .btn{margin-top:0;}
  .emoji-pick{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0;}
  .emoji-pick span{width:38px;height:38px;border-radius:9px;background:var(--card);display:flex;align-items:center;justify-content:center;font-size:19px;cursor:pointer;}
  .emoji-pick span.sel{background:var(--violet-dim);}

  .tools-grid{padding:16px;display:flex;flex-direction:column;gap:10px;overflow-y:auto;}
  .tool-card{background:var(--surface);border-radius:14px;padding:15px;display:flex;align-items:center;gap:14px;cursor:pointer;}
  .tool-card .em{font-size:24px;}
  .tool-card .tx{flex:1;}
  .tool-card .tx b{display:block;font-size:14px;}
  .tool-card .tx span{font-size:12px;color:var(--muted);}
  .gen-loading{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;color:var(--muted);font-size:13px;}
  .spinner{width:32px;height:32px;border:3px solid var(--border);border-top-color:var(--violet);border-radius:50%;animation:spin 0.8s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .md-view{flex:1;overflow-y:auto;padding:20px;line-height:1.6;font-size:14px;}
  .md-view h2{font-size:19px;font-weight:700;margin:16px 0 8px;}
  .md-view h3{font-size:16px;font-weight:700;margin:14px 0 6px;}
  .md-view li{margin-left:18px;margin-bottom:4px;list-style:disc;}
  .md-view p{margin-bottom:6px;}

  .fc-wrap{flex:1;display:flex;flex-direction:column;align-items:center;padding:20px;overflow:hidden;}
  .fc-counter{color:var(--muted);font-size:13px;margin-bottom:14px;}
  .fc-card{width:100%;max-width:380px;flex:1;border-radius:18px;background:var(--card);display:flex;align-items:center;justify-content:center;text-align:center;padding:24px;font-size:17px;font-weight:600;cursor:pointer;overflow-y:auto;}
  .fc-card.flipped{background:var(--violet-dim);}
  .fc-hint{font-size:12px;color:var(--muted);margin:12px 0;flex-shrink:0;}
  .fc-nav{display:flex;gap:14px;flex-shrink:0;}
  .fc-nav .btn{width:auto;min-width:110px;}

  .quiz-wrap{flex:1;display:flex;flex-direction:column;padding:20px;overflow-y:auto;}
  .progress-bar{height:5px;background:var(--border);border-radius:4px;overflow:hidden;margin-bottom:8px;}
  .progress-bar div{height:100%;background:var(--violet);transition:width 0.3s;}
  .q-text{font-size:16px;font-weight:600;margin:14px 0 16px;}
  .q-opt{background:var(--card);border-radius:12px;padding:13px;margin-bottom:8px;font-size:14px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;}
  .q-opt.correct{background:var(--emerald-dim);}
  .q-opt.wrong{background:#4A1D1D;}
  .q-explain{background:var(--card);border-radius:12px;padding:13px;font-size:13px;color:var(--muted);margin-top:6px;}
  .quiz-final{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;}
  .quiz-final .em{font-size:52px;}
  .quiz-final .score{font-size:23px;font-weight:800;}

  .snackbar{position:fixed;bottom:90px;left:16px;right:16px;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:13px 16px;font-size:13px;display:flex;justify-content:space-between;align-items:center;gap:10px;z-index:200;box-shadow:0 4px 16px rgba(0,0,0,0.4);}
  .snackbar button{background:none;border:none;color:var(--violet-light);font-weight:600;font-size:13px;flex-shrink:0;}
</style>
</head>
<body>

<div id="boot-error" class="hidden" style="position:fixed;inset:0;background:#0A0E1F;color:#F8FAFC;padding:24px;font-family:ui-monospace,monospace;font-size:13px;line-height:1.6;white-space:pre-wrap;z-index:9999;overflow-y:auto;">
  <div style="color:#EF4444;font-weight:700;font-size:15px;margin-bottom:10px;">⚠️ The app hit an error while loading</div>
  <div id="boot-error-msg"></div>
  <div style="margin-top:18px;color:#94A3B8;font-family:-apple-system,sans-serif;">Copy this whole message and send it back — that's enough to diagnose it.</div>
</div>

<div id="app">

  <div id="screen-setup" class="screen hidden">
    <div class="setup-wrap">
      <div class="setup-icon">🧠</div>
      <h2>NotebookAI</h2>
      <p>Your free AI research companion.<br>Powered by Google Gemini.</p>
      <div class="info-card">
        <b>Get your free config (~5 min, on this phone):</b>
        <ol>
          <li>Go to <code>console.firebase.google.com</code></li>
          <li>Create a project (free Spark plan)</li>
          <li>Left menu → Build → <b>AI Logic</b> → Get started → choose <b>Gemini Developer API</b></li>
          <li>Project settings (gear icon) → scroll to "Your apps" → click the <code>&lt;/&gt;</code> Web icon → register an app</li>
          <li>Copy the whole <code>firebaseConfig</code> object it shows you</li>
        </ol>
      </div>
      <textarea id="config-input" rows="7" placeholder='Paste your firebaseConfig here, e.g.&#10;{ apiKey: "...", projectId: "...", ... }'></textarea>
      <div id="setup-error" class="error-text hidden"></div>
      <button class="btn" id="setup-save-btn">Get Started</button>
      <p style="font-size:11px;color:var(--muted);margin-top:14px;max-width:420px;">Stored only on this device, never sent anywhere except directly to Google's API.</p>
    </div>
  </div>

  <div id="screen-home" class="screen hidden">
    <div class="topbar">
      <h1>🧠 NotebookAI</h1>
      <button class="icon-btn" id="home-settings-btn">⚙️</button>
    </div>
    <div class="scroll" id="home-body"></div>
    <button class="fab" id="new-notebook-btn">+ New Notebook</button>
  </div>

  <div id="screen-notebook" class="screen hidden">
    <div class="topbar">
      <button class="icon-btn" id="nb-back-btn">←</button>
      <div style="flex:1;text-align:center;overflow:hidden;min-width:0;">
        <div id="nb-title" style="font-weight:700;font-size:15px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
        <div id="nb-subtitle" class="sub"></div>
      </div>
      <div style="display:flex;flex-shrink:0;">
        <button class="icon-btn" id="nb-study-btn">🎓</button>
        <button class="icon-btn" id="nb-add-btn">+</button>
      </div>
    </div>
    <div id="nb-chips" class="chips hidden"></div>
    <div class="tabs">
      <div class="tab active" data-tab="chat">Chat</div>
      <div class="tab" data-tab="notes">Notes</div>
    </div>
    <div id="tab-chat" style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
      <div id="chat-area" class="chat-area"></div>
      <div class="input-bar">
        <textarea id="chat-input" rows="1" placeholder="Ask about your sources…"></textarea>
        <button class="send-btn" id="send-btn">➤</button>
      </div>
    </div>
    <div id="tab-notes" class="hidden" style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
      <div id="notes-list" class="notes-list"></div>
      <div style="padding:12px 16px;flex-shrink:0;">
        <button class="btn" id="add-note-btn" style="margin-top:0;">+ Add Note</button>
      </div>
    </div>
  </div>

  <div id="screen-study" class="screen hidden">
    <div class="topbar">
      <button class="icon-btn" id="study-back-btn">←</button>
      <h1 id="study-title" style="font-size:15px;">Study Tools</h1>
      <div style="width:38px;flex-shrink:0;"></div>
    </div>
    <div id="study-body" style="flex:1;display:flex;flex-direction:column;overflow:hidden;"></div>
  </div>

</div>

<div id="modal-root"></div>
<div id="snackbar-root"></div>

<script type="module">
/* ============== BOOT SAFETY NET ============== */
// If literally anything throws anywhere on the page (including module load
// failures that the rest of this script can't catch), show it instead of a
// blank screen.
function showBootError(msg){
  const box = document.getElementById('boot-error');
  const out = document.getElementById('boot-error-msg');
  if(!box || !out) { console.error(msg); return; }
  out.textContent += (out.textContent ? '\n\n' : '') + msg;
  box.classList.remove('hidden');
}
window.addEventListener('error', (e)=>{
  showBootError('Script error: ' + (e.message||'unknown') + (e.filename ? ('\nFile: '+e.filename+':'+e.lineno) : ''));
});
window.addEventListener('unhandledrejection', (e)=>{
  const r = e.reason;
  showBootError('Unhandled error: ' + (r && r.message ? r.message : String(r)) + (r && r.stack ? ('\n'+r.stack.split('\n').slice(0,3).join('\n')) : ''));
});
setTimeout(()=>{
  const anyVisible = document.querySelector('.screen:not(.hidden)');
  const bootErrorShown = !document.getElementById('boot-error').classList.contains('hidden');
  if(!anyVisible && !bootErrorShown){
    showBootError('Timed out after 5 seconds with nothing rendered, and no error was caught either.\nThis usually means a network/ad-blocker issue silently blocked a script from loading.\nTry: a different network (data instead of wifi, or vice versa), disabling any ad-blocker/VPN, or a different browser.');
  }
}, 5000);

/* ============== LOAD FIREBASE (dynamic, so failures are catchable) ============== */
let initializeApp, getAI, getGenerativeModel, GoogleAIBackend;
async function loadFirebase(){
  const FB_VERSION = '12.14.0';
  try{
    const appMod = await import(`https://www.gstatic.com/firebasejs/${FB_VERSION}/firebase-app.js`);
    initializeApp = appMod.initializeApp;
  }catch(e){
    throw new Error('Could not load firebase-app.js from the CDN: ' + e.message);
  }
  try{
    const aiMod = await import(`https://www.gstatic.com/firebasejs/${FB_VERSION}/firebase-ai.js`);
    getAI = aiMod.getAI; getGenerativeModel = aiMod.getGenerativeModel; GoogleAIBackend = aiMod.GoogleAIBackend;
  }catch(e){
    throw new Error('Could not load firebase-ai.js from the CDN: ' + e.message);
  }
}

/* ============== CONSTANTS ============== */
const SYSTEM_PROMPT = `You are an AI Research Companion and Knowledge Assistant. Your expertise comes primarily
from the user's uploaded materials rather than your own general knowledge.

You act as: Research assistant, Study partner, Note organizer, Knowledge synthesizer,
Project mentor, and Document analyst.

Your highest priority is remaining faithful to the provided sources.

PRIORITY SYSTEM:
Priority 1: Uploaded Sources (treat as primary source of truth)
Priority 2: User Instructions
Priority 3: General Knowledge

If an answer is not supported by uploaded materials, clearly state:
"Not directly found in the provided sources." Then optionally provide general knowledge.

SOURCE-GROUNDED ANSWERING — for every answer:
1. Search uploaded materials first
2. Locate relevant evidence
3. Summarize accurately
4. Cite source locations when available
5. Distinguish between source-based facts and external knowledge

OUTPUT FORMAT:
**Direct Answer:** [your answer]
**Evidence From Sources:** [specific evidence]
**Key Takeaways:** [bullet points]
**Related Questions:** [suggested follow-ups]
**Confidence:** High / Medium / Low

QUALITY RULES:
- Always be factual and transparent
- Show evidence for claims
- Distinguish facts from assumptions
- Admit uncertainty
- Never fabricate citations or invent information

Never pretend information exists in the uploaded material if it does not.`;

const STUDY_PROMPTS = {
  summary: { label:'Summary', emoji:'📋', desc:'Get the big picture in seconds', prompt:
`Generate a comprehensive bu
